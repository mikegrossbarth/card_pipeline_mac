# Required for Photo OCR and Card Ladder screenshot OCR fallback.
GOOGLE_API_KEY=

# Photo OCR reads detected card crops concurrently.
# Use 1 for slower/lower API pressure, 3 for the default, 4 for the fastest supported setting.
LUCAS_PHOTO_OCR_CROP_WORKERS=3

# Dense photos keep looking for this many slab regions before skipping extra detector passes.
# Higher is better for 2-row grid photos, lower is faster for small batches.
LUCAS_PHOTO_OCR_REGION_TARGET=10

# Required for complete setup. Enables Google Sheets rule/payout files in Assignment Rules.
# Create an OAuth Client ID with application type "Desktop app" in Google Cloud.
GOOGLE_SHEETS_OAUTH_CLIENT_ID=
GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=

# Required for complete setup. Point this at your WORKING SHEETS folder.
# If this is set, INCOMING SHEETS, RECEIVED SHEETS, and sheet_markers.json live beside it.
# Example: /Users/yourname/Library/CloudStorage/GoogleDrive-your.email@gmail.com/My Drive/CARD_PIPELINE/WORKING SHEETS
LUCAS_WORKING_SHEETS_DIR=

# Legacy fallback for setups with folders under one pipeline root.
# Example: /Users/yourname/Library/CloudStorage/GoogleDrive-your.email@gmail.com/My Drive/CARD_PIPELINE
LUCAS_PIPELINE_DIR=
